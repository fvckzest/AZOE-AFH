{
  "name": "azoe-afh-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "npm run seo:assets && npm run seo:files",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "seo:assets": "node ./scripts/generate-seo-assets.mjs",
    "seo:files": "node ./scripts/generate-seo-files.mjs",
    "cf:dev": "npm run build && node ./scripts/cloudflare-pages.mjs dev dist",
    "cf:project:create": "node ./scripts/cloudflare-pages.mjs create",
    "cf:deploy": "npm run build && node ./scripts/cloudflare-pages.mjs deploy dist",
    "cf:deploy:skip-build": "node ./scripts/cloudflare-pages.mjs deploy dist",
    "handoff:check": "node ./scripts/check-launch-readiness.mjs && npm run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.10",
    "wrangler": "^4.93.0"
  }
}
